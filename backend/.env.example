# Oracle Cloud Backend - Environment Variables Example
# Set these environment variables in your server running container/process.

# Django Cryptographic Key
DJANGO_SECRET_KEY=generate-a-long-random-string-at-least-50-chars-here-for-production

# Turn off debug mode in production (values: False, 0, no)
DJANGO_DEBUG=False

# CSV-separated hostnames allowed to query Django (your Oracle Cloud backend domain/IP)
DJANGO_ALLOWED_HOSTS=generalusedjango.chickenkiller.com,84.235.166.113,127.0.0.1,localhost

# CSV-separated origins allowed to make CORS requests (your Vercel frontend URL)
DJANGO_CORS_ALLOWED_ORIGINS=https://generaluse-tracker.vercel.app,http://localhost:5173
